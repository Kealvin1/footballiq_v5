# ── REQUIRED ──────────────────────────────────────────────────────────
# Your Anthropic API key — set in Netlify: Site settings → Environment
# Also enter this in the app's ⚙ Settings modal on first use
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# ── OPTIONAL but recommended ──────────────────────────────────────────
# The Odds API key — enables real live odds across 40+ bookmakers
# Free tier: 500 requests/month  →  https://the-odds-api.com
ODDS_API_KEY=your_odds_api_key_here
